tract_demographics <- tract_demographics2 %>%
mutate(
pop_65_plus = rowSums(
select(., matches("male_.*E|female_.*E")),
na.rm = TRUE
)
)
tract_demographics <- tract_demographics %>%
select(GEOID, NAME, total_popE, total_popM, median_incomeE, median_incomeM, pop_65_plus)
# Join to tract boundaries
tracts_proj <- st_transform(tracts,3365)
tract_demographics <- tracts_proj %>%
left_join(tract_demographics, by = "GEOID")
no_income <- tract_demographics %>%
filter(is.na(median_incomeE))
median(tract_demographics$median_incomeE, na.rm = TRUE))
median(tract_demographics$median_incomeE, na.rm = TRUE)
median <- median(tract_demographics$median_incomeE, na.rm = TRUE)
# Filter for vulnerable tracts based on your criteria
tract_demographics <- tract_demographics %>%
mutate(percent_65_plus = pop_65_plus / total_popE)
vulnerable_tracts <- tract_demographics %>%
filter((median_incomeE <= 0.3*75844) | percent_65_plus >= .30)
ggplot() +
geom_sf(data = hospitals, color = "blue") +
geom_sf(data = tract_demographics, color="red") +
theme_void()
# Transform to appropriate projected CRS
tract_demographics <- st_transform(tract_demographics, crs = 3365)
vulnerable_tracts <- st_transform(vulnerable_tracts, crs = 3365)
hospitals <- st_transform(hospitals, crs = 3365)
# Calculate distance from each tract centroid to nearest hospital
tract_centroid <- st_centroid(vulnerable_tracts)
dist_matrix <- st_distance(tract_centroid, hospitals)
nearest_dist <- apply(dist_matrix, 1, min)
vulnerable_tracts$nearest_hospital_dist_ft <- as.numeric(nearest_dist)
vulnerable_tracts <- vulnerable_tracts %>%
mutate(nearest_hospital_dist_miles = as.numeric(nearest_hospital_dist_ft / 5280))
far_away <- vulnerable_tracts %>%
filter(nearest_hospital_dist_miles > 15)
# Create underserved variable
vulnerable_tracts <- vulnerable_tracts %>%
mutate(underserved = ifelse(nearest_hospital_dist_miles > 15, "underserved", "well served"),
underserved_varb = ifelse(nearest_hospital_dist_miles > 15, 1, 0))
far_away <- vulnerable_tracts %>%
filter(nearest_hospital_dist_miles > 15)
# Create underserved variable
vulnerable_tracts <- vulnerable_tracts %>%
mutate(underserved = ifelse(nearest_hospital_dist_miles > 15, "underserved", "well served"),
underserved_varb = ifelse(nearest_hospital_dist_miles > 15, 1, 0))
# Spatial join tracts to counties
counties <- st_read(here("labs/lab_2/labs/Pennsylvania_County_Boundaries/Pennsylvania_County_Boundaries.shp"))
# Aggregate statistics by county
counties <- st_transform(counties, crs=3365)
tract_demographics <- tract_demographics %>%
st_join(counties)
demographcis_centroid <- st_centroid(tract_demographics)
dist_matrix2 <- st_distance(demographcis_centroid, hospitals)
nearest_dist2 <- apply(dist_matrix2, 1, min)
tract_demographics$nearest_hospital_dist_ft <- as.numeric(nearest_dist2)
tract_demographics <- tract_demographics %>%
mutate(nearest_hospital_dist_miles = as.numeric(nearest_hospital_dist_ft / 5280))
tract_demographics <- tract_demographics %>%
mutate(vulnerable = ifelse((percent_65_plus >= .30 | median_incomeE <= 0.3*75844), 1, 0),
underserved = ifelse((nearest_hospital_dist_miles > 15), 1, 0)
)
county_analysis <- tract_demographics %>%
group_by(COUNTY_NAM) %>%
summarize(vulnerable_tracts_county = sum(vulnerable),
underserved_tracts_county = sum(underserved),
per_vul_underserved = sum(vulnerable == 1 & underserved == 1, na.rm = TRUE)/
sum(vulnerable == 1, na.rm = TRUE),
dist_hosp_all = (mean(nearest_hospital_dist_miles)),
dist_hosp_vuln = mean(nearest_hospital_dist_miles[vulnerable == 1], na.rm = TRUE),
total_pop = sum(total_popE, na.rm = TRUE),
vulnerable_pop = sum(
ifelse(vulnerable == 1, total_popE, 0),
na.rm = TRUE
),
geometry = st_union(geometry)
) %>%
mutate(per_vulnerable = vulnerable_pop/total_pop)
vul_far_from_hosp <- county_analysis %>%
filter(dist_hosp_vuln > 15)
