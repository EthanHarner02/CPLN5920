title = "Housing Prices by Neighborhood Value Category",
subtitle = "Neighborhoods Classified by Median Home Price",
color = "Neighborhood Category"
) +
guides(color = guide_legend(
override.aes = list(size = 4, alpha = 1)
)) +
theme_void()
