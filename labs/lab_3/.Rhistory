ggplot(philly_data_working_hoods,
aes(x = dist_to_downtown_miles, y = log(sale_price))) +
geom_point(alpha = 0.15) +
geom_smooth(method = "lm",
formula = y ~ x + I(x^2),
color = "red",
linewidth = 1.2) +
theme_minimal() +
labs(
title = "Nonlinear Relationship Between Distance to Center City and Housing Prices",
x = "Distance to Downtown (miles)",
y = "Log Sale Price"
)
# we need coordinates for each property
coords <- st_coordinates(philly_data_working_hoods)
# find the nearest 5 neighbors for each property, excluding itself
nn <- get.knn(coords, k = 5)
neighbor_price <- apply(nn$nn.index, 1, function(i) {
mean(philly_data_working_hoods$sale_price[i], na.rm = TRUE)
})
philly_data_working_hoods$neighbor_sale_price <- neighbor_price
philly_data_working_hoods$log_neighbor_price <- log(neighbor_price)
summary(philly_data_working_hoods$neighbor_sale_price)
philly_data_working_hoods <- philly_data_working_hoods %>%
mutate(structure_age = (2025 - as.numeric(year_built)))
philly_data_working_hoods <- philly_data_working_hoods %>%
filter(total_livable_area > 0)
hist(philly_data_working_hoods$population_density) #Means I want to log population density in models
hist(philly_data_working_hoods$dist_to_park_miles) #also want to log distance to parks
hist(philly_data_working_hoods$total_livable_area) #same as above
hist(philly_data_working_hoods$dist_to_downtown_miles) #probably also want to log
hist(philly_data_working_hoods$violent_crime_rate) #same
hist(philly_data_working_hoods$buildvacpercentage)
hist(philly_data_working_hoods$sale_price) #makes me think we should chop out sale prices over 20M
philly_data_working_hoods <- philly_data_working_hoods %>%
filter(sale_price < 20000000)
philly_data_working_hoods <- philly_data_working_hoods %>%
filter(location != "6025 JACKSON ST")
philly_data_working_hoods <- philly_data_working_hoods %>%
filter(number_of_bathrooms > 0)
structural_model <-  lm(log(sale_price) ~ as.factor(exterior_condition) + as.factor(building_code_new) + garage_spaces + number_of_bathrooms + number_of_bedrooms + I(structure_age^2) + log(total_livable_area), data = philly_data_working_hoods)
summary(structural_model)
census_model <- lm(log(sale_price) ~ as.factor(exterior_condition) + as.factor(building_code_new) + garage_spaces + number_of_bathrooms + number_of_bedrooms + I(structure_age^2) + log(total_livable_area) + per_bachelors + per_black + per_latino + population_density + median_incomeE, data = philly_data_working_hoods)
summary(census_model)
spatial_model <- lm(log(sale_price) ~ as.factor(exterior_condition) + as.factor(building_code_new) + garage_spaces + number_of_bathrooms + number_of_bedrooms + I(structure_age^2) + log(total_livable_area) +
per_bachelors +
per_black +
per_latino +
population_density +
median_incomeE + dist_to_downtown_miles + dist_to_park_miles + as.factor(close_proximity_to_transit) + as.factor(close_proximity_to_RR) + buildvacpercentage + violent_crime_rate, data = philly_data_working_hoods)
summary(spatial_model)
FE_model <- lm(log(sale_price) ~ as.factor(exterior_condition) + as.factor(building_code_new) + garage_spaces + number_of_bathrooms +number_of_bedrooms + I(structure_age^2) + garage_spaces:population_density + log(total_livable_area) + total_livable_area:as.factor(neighborhood_category) + per_bachelors + per_black + per_latino + log(population_density) + population_density:median_incomeE + log(dist_to_downtown_miles) + log(dist_to_park_miles) + as.factor(close_proximity_to_transit) + as.factor(close_proximity_to_RR) + buildvacpercentage + buildvacpercentage:median_incomeE +  median_incomeE + log(neighbor_sale_price) + log(violent_crime_rate) + as.factor(neighborhood_category), data = philly_data_working_hoods)
summary(FE_model)
set.seed(123)
train_control <- trainControl(method = "cv", number = 10)
cv_model_structural <- train(
log(sale_price) ~ as.factor(exterior_condition) + as.factor(building_code_new) + garage_spaces + number_of_bathrooms + number_of_bedrooms + I(structure_age^2) + log(total_livable_area),
data = philly_data_working_hoods,
method = "lm",
trControl = train_control,
na.action = na.omit
)
print(cv_model_structural)
print(cv_model_structural$results$RMSE)
qqnorm(residuals(structural_model))
qqline(residuals(structural_model), col = "red")
plot(
fitted(structural_model),
residuals(structural_model),
xlab = "Fitted Values",
ylab = "Residuals"
)
abline(h = 0, col = "red")
plot(cooks.distance(structural_model),
type = "h",
ylab = "Cook's Distance")
philly_data_working_hoods[
which.max(cooks.distance(structural_model)),
]
census_model <- lm(log(sale_price) ~ as.factor(exterior_condition) + as.factor(building_code_new) + garage_spaces + number_of_bathrooms + number_of_bedrooms + I(structure_age^2) + log(total_livable_area) + per_bachelors + per_black + per_latino + population_density + median_incomeE, data = philly_data_working_hoods)
summary(census_model)
train_control <- trainControl(
method = "cv",
number = 10
)
#Finding RMSE
cv_model_census <- train(
log(sale_price) ~ as.factor(exterior_condition) + as.factor(building_code_new) + garage_spaces + number_of_bathrooms + number_of_bedrooms + I(structure_age^2) + log(total_livable_area) +
per_bachelors +
per_black +
per_latino +
population_density +
median_incomeE,
data = philly_data_working_hoods,
method = "lm",
trControl = train_control,
na.action = na.omit
)
print(cv_model_census)
print(cv_model_census$results$RMSE)
#Over or under-predicting by 78%!
qqnorm(residuals(census_model))
qqline(residuals(census_model), col = "red")
plot(
fitted(census_model),
residuals(census_model),
xlab = "Fitted Values",
ylab = "Residuals"
)
abline(h = 0, col = "red")
plot(cooks.distance(census_model),
type = "h",
ylab = "Cook's Distance")
philly_data_working_hoods[
which.max(cooks.distance(census_model)),
]
#Finding RMSE
cv_model_spatial <- train(log(sale_price) ~ as.factor(exterior_condition) + as.factor(building_code_new) + garage_spaces + number_of_bathrooms + number_of_bedrooms + I(structure_age^2) + log(total_livable_area) +
per_bachelors +
per_black +
per_latino +
population_density +
median_incomeE + dist_to_downtown_miles + dist_to_park_miles + as.factor(close_proximity_to_transit) + as.factor(close_proximity_to_RR) + buildvacpercentage + violent_crime_rate, data = philly_data_working_hoods,
method = "lm",
trControl = train_control,
na.action = na.omit
)
print(cv_model_spatial)
print(exp(cv_model_spatial$results$RMSE))
#Over or under-predicting by 75%!
qqnorm(residuals(spatial_model))
qqline(residuals(spatial_model), col = "red")
plot(
fitted(spatial_model),
residuals(spatial_model),
xlab = "Fitted Values",
ylab = "Residuals"
)
abline(h = 0, col = "red")
plot(cooks.distance(spatial_model),
type = "h",
ylab = "Cook's Distance")
philly_data_working_hoods[
which.max(cooks.distance(spatial_model)),
]
FE_model <- lm(log(sale_price) ~ as.factor(exterior_condition) + as.factor(building_code_new) + garage_spaces + number_of_bathrooms +number_of_bedrooms + I(structure_age^2) + garage_spaces:population_density + log(total_livable_area) + total_livable_area:as.factor(neighborhood_category) + per_bachelors + per_black + per_latino + log(population_density) + population_density:median_incomeE + log(dist_to_downtown_miles) + log(dist_to_park_miles) + as.factor(close_proximity_to_transit) + as.factor(close_proximity_to_RR) + buildvacpercentage + buildvacpercentage:median_incomeE +  median_incomeE + log(neighbor_sale_price) + log(violent_crime_rate) + as.factor(neighborhood_category), data = philly_data_working_hoods)
summary(FE_model)
#Finding RMSE
cv_model_FE <- train(
log(sale_price) ~ as.factor(exterior_condition) + as.factor(building_code_new) + garage_spaces + number_of_bathrooms +number_of_bedrooms + I(structure_age^2) + garage_spaces:population_density + log(total_livable_area) + total_livable_area:as.factor(neighborhood_category) + per_bachelors + per_black + per_latino + log(population_density) + population_density:median_incomeE + log(dist_to_downtown_miles) + log(dist_to_park_miles) + as.factor(close_proximity_to_transit) + as.factor(close_proximity_to_RR) + buildvacpercentage + buildvacpercentage:median_incomeE +  median_incomeE + log(neighbor_sale_price) + log(violent_crime_rate) + as.factor(neighborhood_category), data = philly_data_working_hoods,
method = "lm",
trControl = train_control,
na.action = na.omit
)
print(cv_model_FE)
print(exp(cv_model_FE$results$RMSE))
#Over or under-predicting by 69.9%!
qqnorm(residuals(FE_model))
qqline(residuals(FE_model), col = "red")
comparison_table <- data.frame(
Model = c("Structural", "Census", "Spatial", "Fixed Effects and Interaction"),
R_squared    = c(
max(cv_model_structural$results$Rsquared),
max(cv_model_census$results$Rsquared),
max(cv_model_spatial$results$Rsquared),
max(cv_model_FE$results$Rsquared)
),
RMSE  = c(
max(cv_model_structural$results$RMSE),
max(cv_model_census$results$RMSE),
max(cv_model_spatial$results$RMSE),
max(cv_model_FE$results$RMSE)
)
)
comparison_table$R_squared   <- round(comparison_table$R_squared, 3)
comparison_table$RMSE <- round(comparison_table$RMSE, 3)
library(kableExtra)
kable(comparison_table, caption = "Model Comparison") %>%
kable_styling(bootstrap_options = c("striped", "hover"))
plot(
fitted(FE_model),
residuals(FE_model),
xlab = "Fitted Values",
ylab = "Residuals"
)
abline(h = 0, col = "red")
plot(cooks.distance(FE_model),
type = "h",
ylab = "Cook's Distance")
philly_data_working_hoods[
which.max(cooks.distance(census_model)),
]
philly_acs <- get_acs(
geography = "tract",
state = "PA",
county = "Philadelphia",
variables = c(
population = "B01003_001",
bachelors = "B15003_022",
black = "B02001_003",
latino = "B03003_003",
native = "B02001_004",
median_income = "B19013_001"
),
year = 2024,
survey = "acs5",
geometry = TRUE,
output = "wide"
)
