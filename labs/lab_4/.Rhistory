# Spatstat for analyzing point patterns - split into sub-packages
library(spatstat.geom)    # Spatial geometries
library(spatstat.explore) # Spatial exploration/KDE
darkness <- read.csv(here("labs/lab_4/data/311_Service_Requests_-_Street_Lights_-_All_Out_-_Historical_20260401.csv"))
darkness <- darkness %>%
filter(!is.na(Latitude) & !is.na(Longitude))
darkness_spatial <- st_as_sf(darkness, coords = c("Longitude", "Latitude"), crs = 4326) |>
st_transform(crs = 3435)
chicagoBoundary <-
st_read("https://raw.githubusercontent.com/urbanSpatial/Public-Policy-Analytics-Landing/master/DATA/Chapter5/chicagoBoundary.geojson") %>%
st_transform(crs = 3435)
p1 <- ggplot() +
geom_sf(data = chicagoBoundary, fill = "gray95", color = "gray60") +
geom_sf(data = darkness_spatial, color = "#d62828", size = 0.05, alpha = 0.4) +
labs(
title = "Streetlights That Have Gone Out",
subtitle = "Completed and Open"
)
