# Spatial join
darkness_fishnet <- st_join(darkness_spatial, fishnet, join = st_within) %>%
st_drop_geometry() %>%
group_by(uniqueID) %>%
summarize(countLights = n())
glimpse(darkness_fishnet)
st_crs(darkness_fishnet)
# Join back to fishnet
fishnet <- fishnet %>%
left_join(darkness_fishnet, by = "uniqueID") %>%
mutate(countLights = replace_na(countLights, 0))
# Summary statistics
cat("\nLights That Have Gone Out:\n")
summary(fishnet$countLights)
cat("\nCells with Lights Out:",
sum(fishnet$countLights == 0),
